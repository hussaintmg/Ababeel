# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/tmp
app/success-stories
app/resources
app/instructors
app/cookie-policy
app/professional-dev/[program]
ex

# credentials and secrets - never commit
**/*.pem
**/*.key
**/service-account*.json
**/credentials*.json
**/*-service-account*.json
public/safetech-*.json

# local file storage
/storage/
/public/uploads/
/uploads/

docs
__tests__
.claude
.swc
